# SuiDrop configuration — copy to .env and fill in.
# Get a free key at https://dashboard.tatum.io  (API Keys section)
TATUM_API_KEY=your-tatum-api-key-here

# Flip this single switch: testnet | devnet | mainnet
SUIDROP_NETWORK=testnet

# Server
SUIDROP_PORT=8080

# Optional Walrus endpoint overrides (blank = built-in defaults per network)
WALRUS_PUBLISHER=
WALRUS_AGGREGATOR=

# Walrus storage duration, in epochs
WALRUS_EPOCHS=5

# Published Move package id (from `sui client publish`). Blank = Walrus-only mode.
SUIDROP_PACKAGE_ID=
